<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.conggua.springboot3.server.mapper.LogMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.conggua.springboot3.server.model.entity.Log">
        <id column="id" property="id"/>
        <result column="trace_id" property="traceId"/>
        <result column="level" property="level"/>
        <result column="time" property="time"/>
        <result column="content" property="content"/>
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, trace_id, level, time, content
    </sql>

    <!-- 删除过期日志 -->
    <delete id="deleteByExpiredTime">
        DELETE FROM sys_log WHERE time &lt; #{thresholdTime} LIMIT 1000
    </delete>
</mapper>