<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.conggua.springboot3.server.mapper.CategoryMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.conggua.springboot3.server.model.entity.Category">
        <id column="id" property="id"/>
        <result column="module" property="module"/>
        <result column="parent_id" property="parentId"/>
        <result column="name" property="name"/>
        <result column="note" property="note"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, module, parent_id, name, note, create_by, create_time, update_by, update_time
    </sql>
</mapper>